        },
        {
          "slug": "c-gold",
          "name": "C Gold",
          "color": "#C9A84C"
        },
        {
          "slug": "c-gold-dim",
          "name": "C Gold Dim",
          "color": "#9a7e38"
        },
        {
          "slug": "c-magenta",
          "name": "C Magenta",
          "color": "#FF69D4"
